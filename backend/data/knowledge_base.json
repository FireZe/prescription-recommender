  "interaction_rules": [
    {
      "id": "aine_antiagregante_hemorragia",
      "match": "class_class",
      "class_a": "aine",
      "class_b": "antiagregante",
      "severity": "high",
      "description": "A associação de um AINE com um antiagregante plaquetário aumenta o risco de hemorragia, sobretudo gastrointestinal."
    },
    {
      "id": "aine_anticoagulante_hemorragia",
      "match": "class_class",
      "class_a": "aine",
      "class_b": "anticoagulante",
      "severity": "high",
      "description": "A associação de um AINE com um anticoagulante aumenta o risco de hemorragia e deve ser evitada ou cuidadosamente monitorizada."
    },
    {
      "id": "aine_aine_duplicacao",
      "match": "class_class",
      "class_a": "aine",
      "class_b": "aine",
      "severity": "high",
      "description": "A utilização concomitante de dois AINEs deve ser evitada devido ao aumento do risco de toxicidade gastrointestinal, renal e hemorrágica."
    },
    {
